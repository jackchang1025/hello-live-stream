{
  "name": "livestream/recording-system",
  "description": "A modern PHP library for multi-platform live streaming recording with clean architecture",
  "type": "library",
  "keywords": [
    "live-stream",
    "streaming",
    "recording",
    "douyin",
    "tiktok",
    "kuaishou",
    "bilibili",
    "huya",
    "douyu",
    "clean-architecture",
    "ddd",
    "php8"
  ],
  "license": "MIT",
  "authors": [
    {
      "name": "LiveStream Team",
      "email": "team@livestream.dev",
      "homepage": "https://github.com/livestream/recording-system"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-pcntl": "*",
    "ext-json": "*",
    "monolog/monolog": "^3.0",
    "php-ffmpeg/php-ffmpeg": "^1.0",
    "psr/log": "^3.0",
    "symfony/process": "^6.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "mockery/mockery": "^1.5",
    "pestphp/pest": "^3.8",
    "phpstan/phpstan": "^1.10",
    "roave/security-advisories": "dev-latest",
    "squizlabs/php_codesniffer": "^3.7",
    "symfony/var-dumper": "^7.3"
  },
  "autoload": {
    "psr-4": {
      "LiveStream\\": "src-new/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests-new/"
    }
  },
  "scripts": {
    "test": "pest",
    "test-coverage": "pest --coverage-html coverage",
    "cs-check": "phpcs --standard=PSR12 src-new/",
    "cs-fix": "phpcbf --standard=PSR12 src-new/",
    "stan": "phpstan analyse src-new/ --level=8",
    "fix": "php-cs-fixer fix src-new/",
    "quality": [
      "@cs-check",
      "@stan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}